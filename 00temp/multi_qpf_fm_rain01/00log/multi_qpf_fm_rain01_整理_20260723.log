    from runner import process
    process(data_key="ecmwf", run_times=["202604081130"],
            is_multi=False, pro_count=4)

  直跑（改 src/runner.py 的 __main__ 传参）:
    python src/runner.py

  命令行:
    python -m cli --help
    python -m cli ecmwf 202604081130
    python -m cli --data-key ecmwf --start 202604081130 --end 202604081800
    python -m cli ecmwf 202604081130 --is-multi --pro-count 4

